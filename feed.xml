---
permalink: /feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="zh-Hant">
  {% assign ui = site.data.i18n["zh-Hant"] %}
  <title>Cyborg Resilience Co-lab — {{ ui.feed.all }}</title>
  <subtitle>{{ ui.feed.subtitle }}</subtitle>
  <link href="{{ '/' | absolute_url }}"/>
  <link rel="self" href="{{ '/feed.xml' | absolute_url }}"/>
  <id>{{ '/' | absolute_url }}</id>
  {% assign all = site.news | concat: site.events | concat: site.records | sort: "date" | reverse %}
  <updated>{{ all.first.date | date_to_xmlschema }}</updated>
  {% include atom-entries.html entries=all %}
</feed>
