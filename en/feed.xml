---
permalink: /en/feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en-US">
  {% assign ui = site.data.i18n["en-US"] %}
  <title>Cyborg Resilience Co-lab — {{ ui.feed.all }}</title>
  <subtitle>{{ ui.feed.subtitle }}</subtitle>
  <link href="{{ '/en/' | absolute_url }}"/>
  <link rel="self" href="{{ '/en/feed.xml' | absolute_url }}"/>
  <id>{{ '/en/' | absolute_url }}</id>
  {% assign all = site.news_en | concat: site.events_en | concat: site.records_en | concat: site.ideas_en | where_exp: "item", "item.draft != true" | sort: "date" | reverse %}
  <updated>{{ all.first.date | default: site.time | date_to_xmlschema }}</updated>
  {% include atom-entries.html entries=all %}
</feed>
