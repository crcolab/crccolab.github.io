---
permalink: /en/ideas/feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en-US">
  {% assign ui = site.data.i18n["en-US"] %}
  <title>Cyborg Resilience Co-lab — {{ ui.feed.ideas }}</title>
  <link href="{{ '/en/ideas/' | absolute_url }}"/>
  <link rel="self" href="{{ '/en/ideas/feed.xml' | absolute_url }}"/>
  <id>{{ '/en/ideas/' | absolute_url }}</id>
  {% assign entries = site.ideas_en | where_exp: "item", "item.draft != true" | sort: "date" | reverse %}
  <updated>{{ entries.first.date | default: site.time | date_to_xmlschema }}</updated>
  {% include atom-entries.html entries=entries %}
</feed>
